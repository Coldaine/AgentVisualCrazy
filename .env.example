# Claude Sidecar Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# OpenRouter API Key (required for multi-model support)
# =============================================================================
# Get your key at: https://openrouter.ai/settings/keys
#
# Two ways to configure:
# 1. Set this environment variable (recommended for sidecar)
# 2. Run `npx opencode-ai` then use /connect command interactively
#
# See: https://opencode.ai/docs/providers/#openrouter
OPENROUTER_API_KEY=your-openrouter-api-key-here

# =============================================================================
# Optional Settings
# =============================================================================

# Override OpenCode command (default: uses npx opencode-ai)
# Set this if you have opencode installed globally
# OPENCODE_COMMAND=opencode

# Default model for sidecars (uses openrouter/ prefix)
# Examples: openrouter/google/gemini-2.5-flash, openrouter/anthropic/claude-3.5-sonnet
# SIDECAR_DEFAULT_MODEL=openrouter/google/gemini-2.5-flash

# Default timeout in minutes for headless mode
# SIDECAR_TIMEOUT=15

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: error | warn | info | debug (default: error)
# - error: Only errors (default, keeps stderr clean for LLM consumption)
# - warn: Errors and warnings
# - info: Errors, warnings, and operational info
# - debug: All logs including verbose debug output
# LOG_LEVEL=error

# =============================================================================
# Model Routing
# =============================================================================

# Disable automatic model routing for subagent tasks (default: false)
# When enabled, sidecar picks cheaper models for exploration tasks automatically
# SIDECAR_DISABLE_MODEL_ROUTING=true

# Override the model used for Explore-type subagent tasks
# Default: a cost-effective model selected automatically
# SIDECAR_EXPLORE_MODEL=openrouter/google/gemini-3-flash-preview

# =============================================================================
# Advanced / Debug
# =============================================================================

# Override config directory (default: ~/.config/sidecar)
# SIDECAR_CONFIG_DIR=/path/to/config

# Override .env file directory (default: ~/.config/sidecar)
# SIDECAR_ENV_DIR=/path/to/env

# Chrome DevTools Protocol debug port for Electron UI testing (default: 9222)
# Set to avoid port conflicts with Chrome
# SIDECAR_DEBUG_PORT=9223

# Mock update state for UI testing: available, updating, success, error
# Only used during development to test the update banner UI
# SIDECAR_MOCK_UPDATE=available
