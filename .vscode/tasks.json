{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install dependencies",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/shadow-agent" },
      "inSessions": true,
      "runOptions": { "runOn": "worktreeCreated" }
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/shadow-agent" },
      "inSessions": true
    },
    {
      "label": "Start Electron app",
      "type": "shell",
      "command": "npm start",
      "options": { "cwd": "${workspaceFolder}/shadow-agent" },
      "inSessions": true
    },
    {
      "label": "Run tests",
      "type": "shell",
      "command": "npm test",
      "options": { "cwd": "${workspaceFolder}/shadow-agent" },
      "inSessions": true
    }
  ]
}
