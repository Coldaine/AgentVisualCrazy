{
  "name": "shadow-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Passive shadow observer that visualizes and interprets agent activity.",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "build:renderer": "vite build",
    "build:electron": "node electron.esbuild.mjs",
    "build": "npm run build:renderer && npm run build:electron",
    "start": "electron dist-electron/main.cjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prompts:generate": "node scripts/generate-prompts.mjs",
    "prompts:check": "node scripts/check-prompts.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "d3-force": "^3.0.0",
    "electron": "^39.8.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-spring": "^9.7.5"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.25.6",
    "typescript": "^5.8.3",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  }
}
